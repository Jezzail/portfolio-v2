{
  "name": "portfolio-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run --config vitest.config.ts --dir __tests__/unit",
    "test:integration": "vitest run --config vitest.config.ts --dir __tests__/integration",
    "test:e2e": "playwright test",
    "test:all": "vitest run --config vitest.config.ts && playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@swc/helpers": "^0.5.21",
    "framer-motion": "^12.38.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
